{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/knowledge/ad_video_knowledge_card",
  "title": "Ad Video Knowledge Card",
  "description": "Curated professional advertising knowledge used by ad-video intelligence retrieval.",
  "type": "object",
  "required": [
    "card_id",
    "version",
    "domain",
    "summary",
    "principles",
    "apply_when",
    "avoid_when",
    "downstream_targets",
    "keywords",
    "source_type",
    "content_hash",
    "failure_patterns",
    "cross_domain_notes",
    "execution_techniques"
  ],
  "additionalProperties": false,
  "properties": {
    "card_id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+\\.[0-9]{3}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "domain": {
      "type": "string",
      "enum": [
        "positioning",
        "audience_insight",
        "hook_mechanic",
        "narrative_arc",
        "emotional_rhythm",
        "visual_rhetoric",
        "proof_logic",
        "product_demo_logic",
        "platform_format",
        "commercial_compliance",
        "cinematography",
        "color_theory",
        "editing_technique",
        "sound_design",
        "music_direction"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "principles": {
      "type": "array",
      "minItems": 5,
      "items": { "type": "string", "minLength": 1 }
    },
    "apply_when": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "avoid_when": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "downstream_targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "idea",
          "script",
          "scene_plan",
          "visual",
          "pacing",
          "audio",
          "format",
          "hook",
          "build",
          "reveal",
          "cta_brand",
          "color",
          "sound",
          "music",
          "editing"
        ]
      }
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_type": {
      "type": "string",
      "enum": ["openmontage-curated"]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "failure_patterns": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "cross_domain_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["domain", "note"],
        "additionalProperties": false,
        "properties": {
          "domain": { "type": "string", "minLength": 1 },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "execution_techniques": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
