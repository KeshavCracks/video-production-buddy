{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/asset_manifest",
  "title": "Asset Manifest",
  "description": "Inventory of generated/sourced assets produced by the Asset Generator.",
  "type": "object",
  "required": ["version", "assets"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "source_tool", "scene_id"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["image", "video", "audio", "narration", "music", "sfx", "diagram", "animation", "code_snippet", "subtitle", "font", "lut"]
          },
          "path": { "type": "string", "description": "Relative path within the pipeline project directory" },
          "source_tool": { "type": "string" },
          "scene_id": { "type": "string" },
          "prompt": { "type": "string", "description": "Generation prompt if AI-generated" },
          "seed": { "type": "integer", "description": "Seed if applicable" },
          "model": { "type": "string", "description": "Model used for generation" },
          "cost_usd": { "type": "number", "minimum": 0 },
          "duration_seconds": { "type": "number", "minimum": 0 },
          "resolution": { "type": "string" },
          "format": { "type": "string" },
          "quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "subtype": { "type": "string", "description": "Sub-classification (e.g. 'background', 'stock', 'generated')" },
          "generation_summary": { "type": "string", "description": "Brief summary of how the asset was generated or sourced" },
          "provider": { "type": "string", "description": "Provider name (e.g. pixabay, google_imagen)" },
          "license": { "type": "string", "description": "License type (e.g. Pixabay License, CC0)" },
          "original_url": { "type": "string", "description": "Source URL if downloaded from a stock service" },
          "product_identity_conditioning": {
            "type": "object",
            "description": "Required for generated image/video assets linked to product-visible scenes. Records how the product identity reference conditioned generation and what the visual sanity check found.",
            "required": [
              "conditioning_mode",
              "generation_tool",
              "generation_model",
              "fidelity_verdict"
            ],
            "additionalProperties": false,
            "properties": {
              "approved_reference_id": {
                "type": "string",
                "description": "product_identity_reference.reference_id used for conditioning. Omit only for text_only_waived."
              },
              "approved_reference_path": {
                "type": "string",
                "description": "Approved reference image path copied from product_identity_reference.selected_reference_image_path. Omit only for text_only_waived."
              },
              "conditioning_mode": {
                "type": "string",
                "enum": [
                  "reference_to_video",
                  "scene_keyframe_to_video",
                  "text_only_waived"
                ]
              },
              "generation_tool": {
                "type": "string"
              },
              "generation_model": {
                "type": "string"
              },
              "fidelity_verdict": {
                "type": "string",
                "enum": ["PASS", "WARN", "FLAG", "NOT_CHECKED"]
              },
              "fidelity_notes": {
                "type": "string"
              },
              "keyframe_path": {
                "type": "string",
                "description": "Extracted keyframe used for identity sanity check."
              },
              "waiver_decision_id": {
                "type": "string",
                "description": "decision_log decision id when conditioning_mode=text_only_waived."
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "conditioning_mode": {
                      "enum": ["reference_to_video", "scene_keyframe_to_video"]
                    }
                  },
                  "required": ["conditioning_mode"]
                },
                "then": {
                  "required": ["approved_reference_id", "approved_reference_path"]
                }
              },
              {
                "if": {
                  "properties": {
                    "conditioning_mode": { "const": "text_only_waived" }
                  },
                  "required": ["conditioning_mode"]
                },
                "then": {
                  "required": ["waiver_decision_id"]
                }
              }
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "total_cost_usd": { "type": "number", "minimum": 0 },
    "metadata": { "type": "object" },
    "style_mode": {
      "type": "string",
      "enum": ["animated", "cinematic"],
      "description": "Render mode locked at proposal. Carried into asset_manifest so downstream stages can branch on it without re-reading production_proposal."
    },
    "pipeline": {
      "type": "string",
      "description": "Pipeline that produced this asset_manifest (e.g. 'ad-video'). Optional informational field."
    },
    "project_id": {
      "type": "string",
      "description": "Project workspace id under projects/. Optional informational field."
    },
    "narration_files": {
      "type": "array",
      "description": "Per-section TTS file inventory (ad-video). Each entry: section_id (matches script.sections[].id), file (path), duration_seconds.",
      "items": {
        "type": "object",
        "required": ["section_id", "file"],
        "additionalProperties": false,
        "properties": {
          "section_id": { "type": "string" },
          "file": { "type": "string" },
          "duration_seconds": { "type": "number", "minimum": 0 }
        }
      }
    },
    "subtitle_file": {
      "type": "string",
      "description": "Path to the generated subtitle file. Conventionally .ass for ad-video (libass needs PlayRes header for predictable sizing)."
    },
    "music_file": {
      "type": "string",
      "description": "Path to the generated/selected music track."
    },
    "narration_durations": {
      "type": "object",
      "description": "Map of section_id → seconds. Mirrors the section-level data in narration_files for quick lookup.",
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "visual_assets": {
      "type": "array",
      "description": "Optional ad-video supplement to assets[] for richer visual-asset metadata. Free-form items.",
      "items": { "type": "object" }
    },
    "sample_clip": {
      "type": "string",
      "description": "Path to the 10–15s sample preview clip generated before full asset generation begins."
    },
    "total_narration_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Sum of narration_files[].duration_seconds. Should ≈ script.total_duration_seconds within ±5%."
    },
    "costs": {
      "type": "array",
      "description": "Per-tool cost log accumulated during asset generation. Sum equals total_cost_usd.",
      "items": {
        "type": "object",
        "required": ["tool", "cost_usd"],
        "additionalProperties": false,
        "properties": {
          "tool": { "type": "string" },
          "cost_usd": { "type": "number", "minimum": 0 }
        }
      }
    }
  },
  "additionalProperties": false
}
