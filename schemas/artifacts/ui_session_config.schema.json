{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video-production-buddy/artifacts/ui_session_config",
  "title": "GenUI Session Config",
  "description": "Framework-backed GenUI session configuration. The browser renders a trusted A2UI/CopilotKit surface and writes only ui_session_response.",
  "type": "object",
  "required": [
    "contract",
    "session_id",
    "project_id",
    "pipeline_type",
    "stage",
    "gate",
    "mode",
    "title",
    "framework",
    "transport",
    "visual_need_assessment",
    "surfaces",
    "actions"
  ],
  "additionalProperties": false,
  "properties": {
    "contract": { "type": "string", "const": "genui_session" },
    "session_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,63}$" },
    "config_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,63}$" },
    "project_id": { "type": "string", "minLength": 1 },
    "pipeline_type": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "minLength": 1 },
    "gate": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["gate_workspace", "media_review_room", "project_cockpit", "background_status"]
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "workspace_kind": {
      "type": "string",
      "enum": [
        "proposal_lock",
        "runtime_selection",
        "script_review",
        "scene_plan_review",
        "product_reference",
        "sample_review",
        "asset_review",
        "music_review",
        "publish_review",
        "media_review",
        "gate_workspace",
        "project_cockpit",
        "background_status"
      ]
    },
    "decision_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$" },
    "resume_token": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,191}$" },
    "expires_at": { "type": "string", "format": "date-time" },
    "stage_policy_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+\\.[A-Za-z0-9_.-]+$" },
    "schema_strategy": { "type": "string", "enum": ["fixed", "dynamic"] },
    "source_artifact_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[A-Fa-f0-9]{64}$"
      },
      "default": {}
    },
    "operation_events": {
      "type": "array",
      "maxItems": 500,
      "items": { "$ref": "#/$defs/operation_event" },
      "default": []
    },
    "event_stream": {
      "type": "object",
      "required": ["transport", "endpoint", "cursor", "replay"],
      "additionalProperties": false,
      "properties": {
        "transport": { "type": "string", "enum": ["sse"] },
        "endpoint": { "type": "string", "const": "/events" },
        "cursor": { "type": "string", "enum": ["sequence"] },
        "supports_last_event_id": { "type": "boolean" },
        "replay": { "type": "boolean" },
        "max_events": { "type": "integer", "minimum": 1, "maximum": 10000 }
      }
    },
    "draft_state": {
      "type": "object",
      "required": ["path", "endpoint", "response_only"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "const": "draft.json" },
        "endpoint": { "type": "string", "const": "/draft" },
        "autosave": { "type": "boolean" },
        "response_only": { "type": "boolean", "const": true }
      }
    },
    "conflict_policy": {
      "type": "object",
      "required": ["source_hash_check", "block_canonical_writes"],
      "additionalProperties": false,
      "properties": {
        "source_hash_check": { "type": "string", "enum": ["on_submit", "not_required"] },
        "block_canonical_writes": { "type": "boolean", "const": true }
      }
    },
    "framework": { "$ref": "#/$defs/framework" },
    "transport": { "$ref": "#/$defs/transport" },
    "visual_need_assessment": { "$ref": "#/$defs/visual_need_assessment" },
    "media_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/media_ref" },
      "default": []
    },
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_ref" },
      "default": []
    },
    "trace_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/trace_ref" },
      "default": []
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/surface" }
    },
    "issues": {
      "type": "array",
      "maxItems": 500,
      "items": { "$ref": "#/$defs/issue" },
      "default": []
    },
    "initial_values": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "actions": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/action" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "framework": {
      "type": "object",
      "required": ["name", "renderer", "packages"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "const": "a2ui" },
        "renderer": { "type": "string", "const": "@copilotkit/a2ui-renderer" },
        "packages": {
          "type": "array",
          "contains": { "const": "@a2ui/react" },
          "items": {
            "type": "string",
            "enum": ["@a2ui/react", "@a2ui/web_core", "@copilotkit/a2ui-renderer"]
          },
          "uniqueItems": true
        }
      }
    },
    "visual_need_assessment": {
      "type": "object",
      "required": [
        "recommended_mode",
        "recommended_tool",
        "linear_chat_sufficient",
        "reasons",
        "required_ui_primitives",
        "confidence",
        "fallback"
      ],
      "additionalProperties": false,
      "properties": {
        "recommended_mode": {
          "type": "string",
          "enum": ["cli", "gate_workspace", "media_review_room", "project_cockpit", "background_status"]
        },
        "recommended_tool": {
          "type": ["string", "null"],
          "enum": ["genui_session", "genui_interaction", null]
        },
        "linear_chat_sufficient": { "type": "boolean" },
        "interaction_kind": { "type": "string" },
        "reasons": {
          "type": "array",
          "maxItems": 32,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 },
          "uniqueItems": true
        },
        "required_ui_primitives": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "enum": [
              "media_player",
              "audio_player",
              "keyframe_strip",
              "scene_rail",
              "transcript_panel",
              "side_by_side_comparison",
              "structured_fields",
              "timecoded_annotation",
              "frame_region_annotation",
              "issue_tracker",
              "approval_attestation",
              "artifact_trace",
              "budget_panel",
              "status_timeline",
              "operation_timeline",
              "tool_operation_card",
              "durable_decision",
              "review_completion"
            ]
          },
          "uniqueItems": true
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "fallback": {
          "type": "string",
          "enum": ["cli", "cli_only_when_browser_fails_or_user_declines", "compatibility_surface_fallback"]
        }
      }
    },
    "transport": {
      "type": "object",
      "required": ["name", "thread_id", "run_id"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "const": "ag-ui" },
        "thread_id": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 }
      }
    },
    "media_ref": {
      "type": "object",
      "required": ["id", "kind", "title"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "kind": { "type": "string", "enum": ["text", "image", "video", "audio", "path"] },
        "title": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/media_path" },
        "text": { "type": "string" },
        "alt": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "text" } } },
          "then": { "required": ["text"] }
        },
        {
          "if": { "properties": { "kind": { "enum": ["image", "video", "audio", "path"] } } },
          "then": { "required": ["path"] }
        }
      ]
    },
    "media_path": {
      "type": "string",
      "pattern": "^/media/(?:[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*)(?:/(?:[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*))*$"
    },
    "artifact_ref": {
      "type": "object",
      "required": ["id", "artifact", "path", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "artifact": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*$" },
        "label": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" }
      }
    },
    "trace_ref": {
      "type": "object",
      "required": ["id", "label", "source", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "surface": {
      "type": "object",
      "required": ["id", "type", "title"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "type": {
          "type": "string",
          "enum": [
            "GateWorkspace",
            "MediaReviewRoom",
            "IssueTracker",
            "ProjectCockpit",
            "BackgroundStatus",
            "ProposalLock",
            "ScriptReviewWorkspace",
            "ScenePlanWorkspace",
            "ProductReferenceApproval",
            "SampleReview",
            "AssetReview",
            "MusicReview",
            "PublishReview"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "workspace_kind": { "type": "string", "minLength": 1 },
        "contract": { "$ref": "#/$defs/workspace_contract" },
        "media_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" }
        },
        "artifact_ref_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" }
        },
        "trace_ref_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" }
        },
        "required_evidence": {
          "type": "array",
          "items": { "type": "string", "enum": ["media_opened", "timeline_inspected", "approval_attested"] },
          "uniqueItems": true
        },
        "allowed_targets": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" }
        },
        "allowed_statuses": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue_status" }
        }
      }
    },
    "operation_event": {
      "type": "object",
      "required": ["id", "type", "status", "label"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$" },
        "type": { "type": "string", "enum": ["tool_call", "stage", "validation", "render", "status"] },
        "tool": { "type": "string", "maxLength": 256 },
        "status": { "type": "string", "enum": ["pending", "running", "complete", "failed", "blocked"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "workspace_contract": {
      "type": "object",
      "required": ["workspace_kind", "canonical_writes", "response_artifact", "allowed_actions"],
      "additionalProperties": true,
      "properties": {
        "workspace_kind": { "type": "string", "minLength": 1 },
        "canonical_writes": { "type": "boolean", "const": false },
        "response_artifact": { "type": "string", "const": "ui_session_response" },
        "allowed_actions": {
          "type": "array",
          "items": { "type": "string", "enum": ["submit", "approve", "revise", "abort", "open_gate", "refresh"] },
          "uniqueItems": true
        },
        "required_evidence": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "artifact_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field_id", "artifact", "path"],
            "additionalProperties": false,
            "properties": {
              "field_id": { "type": "string", "minLength": 1 },
              "artifact": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "pattern": "^[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*$" }
            }
          }
        },
        "issue_targets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "label", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["submit", "approve", "revise", "abort", "open_gate", "refresh"] },
        "recommended": { "type": "boolean" }
      }
    },
    "issue_status": {
      "type": "string",
      "enum": ["open", "accepted", "rejected", "resolved", "needs_recheck", "waived"]
    },
    "issue": {
      "type": "object",
      "required": ["id", "target_ref", "status", "severity", "requested_change"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "target_ref": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "status": { "$ref": "#/$defs/issue_status" },
        "severity": { "type": "string", "enum": ["blocking", "major", "minor", "note"] },
        "requested_change": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "artifact": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*$" }
      }
    }
  }
}
