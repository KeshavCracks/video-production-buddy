{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-production-buddy.local/schemas/agent_components.schema.json",
  "title": "Video Production Buddy Agent Component Dependencies",
  "type": "object",
  "required": ["version", "materialize", "sources"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "materialize": {
      "type": "object",
      "required": ["agents_dir", "claude_dir"],
      "additionalProperties": false,
      "properties": {
        "agents_dir": { "type": "string", "minLength": 1 },
        "claude_dir": { "type": "string", "minLength": 1 },
        "default_mode": { "enum": ["copy", "symlink"] }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
        "uniqueItems": true
      }
    },
    "sources": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
      "additionalProperties": {
        "type": "object",
        "required": ["type", "components"],
        "additionalProperties": false,
        "properties": {
          "type": { "enum": ["local", "git"] },
          "root": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "ref": { "type": "string", "minLength": 1 },
          "components": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": { "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
            "additionalProperties": {
              "type": "object",
              "required": ["kind", "path"],
              "additionalProperties": false,
              "properties": {
                "kind": { "enum": ["skill", "plugin"] },
                "path": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "local" } } },
            "then": { "required": ["root"] }
          },
          {
            "if": { "properties": { "type": { "const": "git" } } },
            "then": { "required": ["url", "ref"] }
          }
        ]
      }
    }
  }
}
